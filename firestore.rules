rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ------------------------------------------------------------
    //  Per-game high scores  —  scores/{uid}
    // ------------------------------------------------------------
    //  Reads: any signed-in player (needed for the leaderboard).
    //  Writes: BLOCKED for everyone. Scores are written only by the
    //  server (/api/submit-score) via the Firebase Admin SDK, which
    //  bypasses these rules. This makes the "type a score in the
    //  browser console" cheat impossible — the client can't write here.
    match /scores/{userId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ------------------------------------------------------------
    //  User profiles (chosen username)  —  users/{uid}
    // ------------------------------------------------------------
    //  Still written client-side (low risk), but validated server-side
    //  by these rules: only a well-formed username + optional timestamp.
    match /users/{userId} {
      allow read: if request.auth != null;

      allow write: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['username', 'createdAt'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.username.matches('^[a-zA-Z0-9_]+$')
        && (
             !('createdAt' in request.resource.data.keys())
             || request.resource.data.createdAt is number
           );
    }

    // Legacy public 'leaderboard' collection removed — nothing reads or
    // writes it anymore. Anything without an explicit rule is denied by default.
  }
}
